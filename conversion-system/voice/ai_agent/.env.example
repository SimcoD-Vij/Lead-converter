"""
Example .env file for AI Agent Service
Copy this to .env and fill in your API keys
"""

# AI Agent Service Configuration
AI_AGENT_HOST=0.0.0.0
AI_AGENT_PORT=8001
DEBUG=false

# LLM Configuration (OpenAI GPT-4)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# TTS Configuration (OpenAI TTS)
TTS_PROVIDER=openai
TTS_VOICE=alloy
TTS_MODEL=tts-1

# STT Configuration (Deepgram)
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=your-deepgram-api-key-here
STT_MODEL=nova-2
STT_LANGUAGE=en-US
