# ==========================================
# HIVERICKS SYSTEM CONFIGURATION (TEMPLATE)
# ==========================================
# Instructions:
# 1. Copy this file and rename it to ".env"
# 2. Fill in the values below with your actual API keys.

# --- SYSTEM SETTINGS ---
# The URL where this server is accessible (e.g., ngrok URL or public IP)
SERVER_URL=https://your-ngrok-domain.ngrok-free.dev
# Tracking domain, usually same as Server URL
TRACKING_DOMAIN=https://your-ngrok-domain.ngrok-free.dev

# --- INTEGRATIONS ---
# Kickbox Email Verification API
KICKBOX_API_KEY=your_kickbox_api_key

# Abstract API (Phone Validation)
ABSTRACT_API_KEY=your_abstract_api_key

# Email Credentials (Gmail / SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# --- TWILIO (VOICE & SMS) ---
TWILIO_SID=your_twilio_account_sid
TWILIO_AUTH=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# --- AI & CONTEXT ---
# Context7 (or similar) API Key
CONTEXT7_API_KEY=ctx7sk-your-key
# CRM Connection (e.g., SuiteCRM or custom)
CRM_PUBLIC_URL=http://host.docker.internal:8080

# --- OTHER ---
EXPO_CRM=your_expo_crm_key
